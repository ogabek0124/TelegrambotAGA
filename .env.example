# 🌐 ENVIRONMENT MODE
# Development: True | Production: False
DEBUG=False

# 📍 ALLOWED HOSTS
# Render domain: englishbot-api.onrender.com
# Custom domain: yourdomain.com
# Local: localhost,127.0.0.1
ALLOWED_HOSTS=englishbot-api.onrender.com,localhost,127.0.0.1

# 🤖 BOT MODE
# polling - Long polling (default, server'dan yuqorida ko'p CPU)
# webhook - Webhook (production'da optimal)
BOT_MODE=polling

# 📧 EMAIL (optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# 🛡️ SECURITY
# CSRF hosts
CSRF_TRUSTED_ORIGINS=https://englishbot-api.onrender.com

# 📊 LOGGING
LOG_LEVEL=INFO

