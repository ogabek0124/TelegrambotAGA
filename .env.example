# /newbot → username va token olish
BOT_TOKEN=8076309526:AAGQueK-PFsJJYLdAl7g0cFggWdqvC3TFIc

# 🗄️ DATABASE - Neon PostgreSQL
# Neon console'dan connection string copy qilish
# https://console.neon.tech/
